# Optional brand/display name. Falls back to "SkinAlpha v2" if omitted.
NEXT_PUBLIC_APP_NAME=SkinAlpha v2
# Browser requests should stay same-origin so the session cookie is set on the
# frontend domain and remains readable to Next.js server components.
NEXT_PUBLIC_API_BASE_URL=/api
# Server-side only absolute backend base URL used by Next.js during SSR.
SERVER_API_BASE_URL=http://localhost:3001/api
# Server-side only. Keep this aligned with the backend value.
SESSION_COOKIE_NAME=skinalpha_session
