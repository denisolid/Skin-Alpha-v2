NODE_ENV=development
APP_RUNTIME=all
APP_NAME=SkinAlpha v2 API
PORT=3001
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/skinalpha_v2?schema=public
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
QUEUE_PREFIX=skinalpha:v2
SESSION_COOKIE_NAME=skinalpha_session
SESSION_TTL_DAYS=30
SESSION_SECURE_COOKIE=false
SESSION_COOKIE_SAME_SITE=lax
AUTH_STATE_TTL_SECONDS=600
AUTH_EXTERNAL_REDIRECT_URL=http://localhost:3000
LOG_LEVEL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback
GOOGLE_OIDC_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration
STEAM_API_KEY=
STEAM_OPENID_REALM=http://localhost:3001
STEAM_OPENID_RETURN_URL=http://localhost:3001/api/auth/steam/callback
STEAM_OPENID_ENDPOINT=https://steamcommunity.com/openid/login
# Skinport public market endpoints used by the adapter below do not require auth.
# Credentials are only placeholders for future private/account endpoints.
SKINPORT_API_BASE_URL=https://api.skinport.com/v1
SKINPORT_WEBSOCKET_URL=wss://skinport.com
SKINPORT_CURRENCY=EUR
SKINPORT_APP_ID=730
SKINPORT_TRADABLE_ONLY=true
SKINPORT_ITEMS_SYNC_ENABLED=true
SKINPORT_SALES_HISTORY_SYNC_ENABLED=true
SKINPORT_WEBSOCKET_ENABLED=false
SKINPORT_WEBSOCKET_LOCALE=en
SKINPORT_CACHE_TTL_SECONDS=300
SKINPORT_RATE_LIMIT_WINDOW_SECONDS=300
SKINPORT_RATE_LIMIT_MAX_REQUESTS=8
SKINPORT_CLIENT_ID=
SKINPORT_CLIENT_SECRET=
# CSFloat market ingestion currently expects a developer API key.
# Configure endpoint budgets conservatively and let response headers tighten them.
CSFLOAT_API_BASE_URL=https://csfloat.com/api/v1
CSFLOAT_API_KEY=
CSFLOAT_CURRENCY=USD
CSFLOAT_FULL_SYNC_ENABLED=true
CSFLOAT_HOT_UNIVERSE_SYNC_ENABLED=true
CSFLOAT_LISTINGS_PAGE_LIMIT=50
CSFLOAT_LISTINGS_PAGE_BUDGET=20
CSFLOAT_DETAIL_JOB_BUDGET=5
CSFLOAT_LISTINGS_RATE_LIMIT_WINDOW_SECONDS=60
CSFLOAT_LISTINGS_RATE_LIMIT_MAX_REQUESTS=20
CSFLOAT_DETAIL_RATE_LIMIT_WINDOW_SECONDS=60
CSFLOAT_DETAIL_RATE_LIMIT_MAX_REQUESTS=20
# DMarket trading API uses signed Ed25519 requests. Keep it disabled until the
# official API keys are provisioned and rate limits are validated in production.
ENABLE_DMARKET=false
DMARKET_API_BASE_URL=https://api.dmarket.com
DMARKET_PUBLIC_KEY=
DMARKET_SECRET_KEY=
DMARKET_CURRENCY=USD
DMARKET_PAGE_LIMIT=50
DMARKET_BATCH_SIZE=6
DMARKET_BATCH_BUDGET=2
DMARKET_RATE_LIMIT_WINDOW_SECONDS=60
DMARKET_RATE_LIMIT_MAX_REQUESTS=20
ENABLE_WAXPEER=false
WAXPEER_API_BASE_URL=https://api.waxpeer.com
WAXPEER_API_KEY=
WAXPEER_GAME=csgo
WAXPEER_CURRENCY=USD
WAXPEER_NAME_BATCH_SIZE=12
WAXPEER_BATCH_BUDGET=2
WAXPEER_RATE_LIMIT_WINDOW_SECONDS=60
WAXPEER_RATE_LIMIT_MAX_REQUESTS=20
# Additional direct/reference markets. Keep them disabled until the relevant
# credentials and response-shape validation are ready.
ENABLE_BITSKINS=false
BITSKINS_API_BASE_URL=https://api.bitskins.com
BITSKINS_API_KEY=
BITSKINS_CURRENCY=USD
# BitSkins currently exposes a full aggregate snapshot. Keep these conservative
# because SkinAlpha only persists the bounded overlap-target slice downstream.
BITSKINS_PAGE_LIMIT=60
BITSKINS_BATCH_SIZE=20
BITSKINS_BATCH_BUDGET=1
BITSKINS_RATE_LIMIT_WINDOW_SECONDS=60
BITSKINS_RATE_LIMIT_MAX_REQUESTS=24

ENABLE_YOUPIN=false
YOUPIN_REFERENCE_ONLY=true
YOUPIN_API_BASE_URL=https://api.youpin898.com
YOUPIN_API_KEY=
YOUPIN_CURRENCY=CNY
YOUPIN_PAGE_LIMIT=60
YOUPIN_BATCH_SIZE=20
YOUPIN_BATCH_BUDGET=6
YOUPIN_RATE_LIMIT_WINDOW_SECONDS=60
YOUPIN_RATE_LIMIT_MAX_REQUESTS=20

ENABLE_C5GAME=false
C5GAME_API_BASE_URL=https://api.c5game.com
C5GAME_API_KEY=
C5GAME_CURRENCY=CNY
C5GAME_PAGE_LIMIT=50
C5GAME_BATCH_SIZE=20
C5GAME_BATCH_BUDGET=4
C5GAME_RATE_LIMIT_WINDOW_SECONDS=60
C5GAME_RATE_LIMIT_MAX_REQUESTS=18

ENABLE_CSMONEY=false
CSMONEY_API_BASE_URL=https://cs.money
CSMONEY_API_KEY=
CSMONEY_CURRENCY=USD
CSMONEY_PAGE_LIMIT=50
CSMONEY_BATCH_SIZE=15
CSMONEY_BATCH_BUDGET=3
CSMONEY_RATE_LIMIT_WINDOW_SECONDS=60
CSMONEY_RATE_LIMIT_MAX_REQUESTS=12
# Steam snapshot source uses public Community Market price snapshots only.
# It should remain a conservative cached source, never a live scanner dependency.
STEAM_SNAPSHOT_ENABLED=true
STEAM_SNAPSHOT_API_BASE_URL=https://steamcommunity.com/market
STEAM_SNAPSHOT_APP_ID=730
STEAM_SNAPSHOT_CURRENCY_CODE=1
STEAM_SNAPSHOT_COUNTRY=US
STEAM_SNAPSHOT_LANGUAGE=english
STEAM_SNAPSHOT_BATCH_SIZE=20
STEAM_SNAPSHOT_BATCH_BUDGET=5
STEAM_SNAPSHOT_REQUEST_DELAY_MS=1500
STEAM_SNAPSHOT_STALE_AFTER_MINUTES=120
STEAM_SNAPSHOT_MAX_STALE_MINUTES=1440
STEAM_SNAPSHOT_RATE_LIMIT_WINDOW_SECONDS=60
STEAM_SNAPSHOT_RATE_LIMIT_MAX_REQUESTS=30
# Backup aggregators are reference-only. They should improve resilience and
# sanity checks, but they must not replace direct primary market truth.
BACKUP_AGGREGATOR_ENABLED=true
BACKUP_AGGREGATOR_BATCH_SIZE=25
BACKUP_AGGREGATOR_BATCH_BUDGET=3
BACKUP_AGGREGATOR_STALE_AFTER_MINUTES=240
# Example concrete provider implementation: cs2.sh latest prices API.
# Configure the bearer token and reference source set here if you enable it.
BACKUP_AGGREGATOR_CS2SH_ENABLED=false
BACKUP_AGGREGATOR_CS2SH_API_BASE_URL=https://api.cs2.sh
BACKUP_AGGREGATOR_CS2SH_API_KEY=
BACKUP_AGGREGATOR_CS2SH_REQUEST_TIMEOUT_MS=20000
BACKUP_AGGREGATOR_CS2SH_REFERENCE_SOURCES=steam,skinport,csfloat
# Lightweight recurring scheduler. The scheduler only decides whether to
# enqueue work; source adapters and processors still perform the real sync flow.
SCHEDULER_ENABLED=true
SCHEDULER_FAILURE_COOLDOWN_MINUTES=12
SCHEDULER_DEGRADED_INTERVAL_MULTIPLIER=1.5
SCHEDULER_DOWN_INTERVAL_MULTIPLIER=2.25
SCHEDULER_CSFLOAT_MIN_INTERVAL_MINUTES=5
SCHEDULER_DMARKET_MIN_INTERVAL_MINUTES=10
SCHEDULER_WAXPEER_MIN_INTERVAL_MINUTES=8
SCHEDULER_STEAM_SNAPSHOT_MIN_INTERVAL_MINUTES=5
SCHEDULER_SKINPORT_MIN_INTERVAL_MINUTES=5
SCHEDULER_BITSKINS_MIN_INTERVAL_MINUTES=20
SCHEDULER_BACKUP_SOURCE_MIN_INTERVAL_MINUTES=15
SCHEDULER_MARKET_STATE_REBUILD_ENABLED=false
SCHEDULER_MARKET_STATE_REBUILD_MIN_INTERVAL_MINUTES=180
SCHEDULER_OPPORTUNITY_RESCAN_ENABLED=true
SCHEDULER_OPPORTUNITY_RESCAN_MIN_INTERVAL_MINUTES=5
SCHEDULER_OPPORTUNITY_RESCAN_MIN_CHANGED_STATES=24
SCHEDULER_OPPORTUNITY_RESCAN_MIN_HOT_UPDATES=6
